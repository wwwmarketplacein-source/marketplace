generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  firstName     String
  lastName      String
  phoneNumber   String?
  personalEmail String?
  role          UserRole
  isActive      Boolean    @default(true)
  emailVerified Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  company       Company?
  kycRecord     KYCRecord?
}

model Company {
  id                 String      @id @default(cuid())
  legalName          String
  tradingName        String?
  registrationNumber String      @unique
  businessType       String
  industry           String[]
  addressLine1       String
  city               String
  postalCode         String
  annualTurnover     Float?
  companyEmail       String
  phoneNumber1       String
  phoneNumber2       String?
  websiteUrl         String?
  kybStatus          KYBStatus   @default(PENDING)
  userId             String      @unique
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               User        @relation(fields: [userId], references: [id])
  kybRecords         KYBRecord[]
}

model KYBRecord {
  id              String        @id @default(cuid())
  status          KYBStatus     @default(PENDING)
  rejectionReason String?
  companyId       String
  submittedAt     DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  documents       KYBDocument[]
  company         Company       @relation(fields: [companyId], references: [id])
}

model KYBDocument {
  id            String    @id @default(cuid())
  docType       String
  fileName      String
  mimeType      String
  fileSize      Int
  cloudinaryUrl String
  kybRecordId   String
  uploadedAt    DateTime  @default(now())
  kybRecord     KYBRecord @relation(fields: [kybRecordId], references: [id])
}

model KYCRecord {
  id             String   @id @default(cuid())
  designation    String
  phone          String
  idType         String
  idNumber       String
  selfieFileName String?
  selfieUrl      String?
  userId         String   @unique
  submittedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

enum KYBStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  ADMIN
  BUYER
  VENDOR
  INVESTOR
}
